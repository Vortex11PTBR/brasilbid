# ── BrasilBid — Airflow com dependências do projeto ─────────────────────────
FROM apache/airflow:2.9.3-python3.11

USER root
RUN apt-get update && apt-get install -y --no-install-recommends git curl \
    && rm -rf /var/lib/apt/lists/*
USER airflow

# Dependências do pipeline BrasilBid
RUN pip install --no-cache-dir \
        requests \
        pandas \
        python-dotenv \
        sqlalchemy \
        pg8000 \
        dbt-postgres
