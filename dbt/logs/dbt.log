    TRIM(situacao_nome)                                 AS situacao_nome,
    data_publicacao::DATE                               AS data_publicacao,
    data_encerramento::DATE                             AS data_encerramento,
    link_edital,
    numero_compra,
    ano_compra,
    ingested_at
FROM "neondb"."public"."licitacoes"
WHERE numero_controle_pncp IS NOT NULL
  );
